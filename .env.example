NODE_ENV=development
PORT=8787
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# GitHub API settings
GITHUB_API_BASE_URL=https://api.github.com
# Optional: used for GitHub API repo listing and clone authentication.
# If omitted, app will try `gh auth token`.
# GITHUB_API_TOKEN=...

# Local repository mirror root (one mirror per selected repo)
REPO_LOCAL_PATH=.local/repo-mirror

# Copilot CLI runner settings
COPILOT_COMMAND=copilot
COPILOT_DEFAULT_MODEL=gpt-5-mini
COPILOT_AVAILABLE_MODELS_JSON=["gpt-5-mini","raptor-mini","gpt-5","claude-sonnet-4.5"]
# Must be a JSON string array. {{prompt}} will be replaced at runtime.
COPILOT_ARGS_JSON=["--prompt","{{prompt}}","--reasoning-effort","medium","--allow-all-tools","--silent"]
COPILOT_TIMEOUT_MS=90000

# Note: Copilot child process strips GH_TOKEN/GITHUB_TOKEN/COPILOT_GITHUB_TOKEN
# and relies on prior `copilot -i "/login"` device-flow authentication.